{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "api",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "php artisan optimize:clear && php artisan optimize && php artisan serve --port=9191"],
      "cwd": "api",
      "port": 9191
    },
    {
      "name": "api-queue",
      "runtimeExecutable": "php",
      "runtimeArgs": ["artisan", "queue:work", "database", "--timeout=3000", "--tries=5", "--queue=high,low,default,subscriptions"],
      "cwd": "api"
    },
    {
      "name": "web",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["run", "dev"],
      "cwd": "web",
      "port": 3000
    },
    {
      "name": "ai-service",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "source .venv/bin/activate && fastapi dev"],
      "cwd": "ai-service",
      "port": 8000
    },
    {
      "name": "data-service",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "source .venv/bin/activate && uvicorn app.main:app --reload --port 9999"],
      "cwd": "data-service",
      "port": 9999
    },
    {
      "name": "mailhog",
      "runtimeExecutable": "mailhog",
      "runtimeArgs": [],
      "port": 8025
    }
  ]
}
