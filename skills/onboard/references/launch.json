{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "api",
      "runtimeExecutable": "nix",
      "runtimeArgs": ["develop", "--command", "bash", "-c", "cd api && php artisan optimize:clear && php artisan optimize && php artisan serve --port=9191"],
      "port": 9191
    },
    {
      "name": "api-queue",
      "runtimeExecutable": "nix",
      "runtimeArgs": ["develop", "--command", "bash", "-c", "cd api && php artisan queue:work database --timeout=3000 --tries=5 --queue=high,low,default,subscriptions"]
    },
    {
      "name": "web",
      "runtimeExecutable": "nix",
      "runtimeArgs": ["develop", "--command", "bash", "-c", "cd web && bun run dev"],
      "port": 3000
    },
    {
      "name": "ai-service",
      "runtimeExecutable": "nix",
      "runtimeArgs": ["develop", "--command", "bash", "-c", "cd ai-service && source .venv/bin/activate && fastapi dev"],
      "port": 8000
    },
    {
      "name": "data-service",
      "runtimeExecutable": "nix",
      "runtimeArgs": ["develop", "--command", "bash", "-c", "cd data-service && source .venv/bin/activate && uvicorn app.main:app --reload --port 9999"],
      "port": 9999
    },
    {
      "name": "mailhog",
      "runtimeExecutable": "nix",
      "runtimeArgs": ["develop", "--command", "mailhog"],
      "port": 8025
    }
  ]
}
